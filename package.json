  "funding": "https://github.com/sidgaikwad/winter",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build --summarize",
    "check-types": "turbo run check-types --summarize",
    "clean": "bunx rimraf --glob \"**/.next\" \"**/.turbo\" \"**/dist\" \"**/node_modules\" && bunx delete-empty",
    "dev": "turbo run dev --ui tui",
    "devtools": "turbo devtools",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "postinstall": "bun .github/scripts/deps-manager.ts",
    "lint": "turbo run lint",
    "shadcn:update": "bash .github/scripts/shadcn-update.sh",
    "start": "turbo run start"
  },
